  "chronic_themes": [
    {
      "theme_id": "T001",
      "theme": "Mismatched expectation at sale",
      "first_seen": "2026-W15",
      "last_seen": "2026-W18",
      "recurrence_count": 4,
      "lifecycle": "RISING",
      "heat_score": 7,
      "okr": "OKR3",
      "notes": "Venues signing up with a different understanding of how the product works \u2014 discount applies to total bill, brand calibre promises, commission model surprises. Gap between BDM pitch and reality surfaces as early churn. Most common specific misalignment: discount-applies-to-total-bill. Venues: Sushi Mami, Honest Crust, Fress, Persian Kebab.",
      "jira_raised": false,
      "consolidated_from": [
        "T009"
      ]
    },
    {
      "theme_id": "T002",
      "theme": "Over-reliance on AMs and lack of venue autonomy",
      "first_seen": "2026-W12",
      "last_seen": "2026-W18",
      "recurrence_count": 8,
      "lifecycle": "CHRONIC",
      "heat_score": 9,
      "okr": "OKR1",
      "notes": "Venues can't self-serve basic config \u2014 NCI boost, seat times, guest limits, party size, no-show buffer, opening hours. AMs absorb the cost manually via Slack ops channels. When AM is unavailable (vacation, unassigned), venues in distress go unanswered and churn. Limerick Arms explicitly stated can't enable NCI boost on portal. 8+ distinct manual requests per week. Most direct OKR1 opportunity. AM vacation gap: The Nuns Pool, Friends & Flowers Cafe.",
      "jira_raised": false,
      "consolidated_from": [
        "T007",
        "T006"
      ]
    },
    {
      "theme_id": "T003",
      "theme": "Poor customer behaviour",
      "first_seen": "2026-W11",
      "last_seen": "2026-W18",
      "recurrence_count": 9,
      "lifecycle": "CHRONIC",
      "heat_score": 8,
      "okr": "OKR3",
      "notes": "Customers exploiting offers in ways venues can't prevent \u2014 dine-in vouchers for takeaway, oversized parties, repeat redemptions, arriving outside booking windows, leaving without paying. Venues losing margin and losing trust in EatClub's customer quality. Dangerous new pattern: Lulo Spice using T&C abuse as justification for non-payment of debt. Confirmed churns: Plat Coffee, Lumen Alley, Thornbury Taphouse, Lulo Spice. Active risks: The Last Jar (4th cancel attempt), Annata, Forno 88 ($643 fraud attempt).",
      "jira_raised": false,
      "consolidated_from": [
        "T002",
        "T010"
      ]
    },
    {
      "theme_id": "T004",
      "theme": "Platform reliability and trust",
      "first_seen": "2026-W15",
      "last_seen": "2026-W18",
      "recurrence_count": 5,
      "lifecycle": "RISING",
      "heat_score": 8,
      "okr": "OKR2",
      "notes": "Venues configuring their deals and the platform ignoring them \u2014 deal settings reverting, holiday hours overriding manual choices, TA orders firing when offers are off. Silent product failures: Masala Flames iOS dine-in invisible for 5+ months (Partner Signup not found error, restID: 6A3A7879-EACD-4ACF-BA44-770D4608CF9C). Performance tab usage near zero despite active Portal engagement \u2014 venues managing deals blind. Both erode the same thing: confidence that the platform does what it's supposed to do.",
      "jira_raised": false,
      "consolidated_from": [
        "T005",
        "T008"
      ]
    },
    {
      "theme_id": "T005",
      "theme": "High fees and misconception of value",
      "first_seen": "2026-W14",
      "last_seen": "2026-W18",
      "recurrence_count": 6,
      "lifecycle": "CHRONIC",
      "heat_score": 8,
      "okr": "OKR3",
      "notes": "Venues don't believe EatClub is worth what they're paying. Manifests as fee complaints, deal score zero (venues disengaging from deal management), and POS integration cited as reason to leave (surface justification for underlying value perception failure). 397 venues at deal score zero as of W16. Riwayat saved with 3-month fee waiver. TacoBar, Subway Crows Nest, Roseberry Street Cafe citing cost pressure. Performance tab invisibility compounds this \u2014 venues can't see their own ROI.",
      "jira_raised": false,
      "consolidated_from": [
        "T001",
        "T003"
      ]
    },
    {
      "theme_id": "T006",
      "theme": "No group or enterprise product layer",
      "first_seen": "2026-W16",
      "last_seen": "2026-W18",
      "recurrence_count": 3,
      "lifecycle": "RISING",
      "heat_score": 7,
      "okr": "OKR3",
      "notes": "EatClub built for single venues. Multi-venue operators signing up but no group account layer, no multi-venue visibility, no relationship above individual AM. When one venue churns or owner disengages, all venues go with no early warning. Two confirmed cascade churns: Ramen Ippudo (8 venues), Gogyo (pattern identical \u2014 AM can't access decision-makers, POC gatekeeps). Mr Ramen San: 2-venue cascade from single $65.63 billing error. Jak's Group (7 venues, liquidation). Structural vulnerability clear.",
      "jira_raised": false,
      "consolidated_from": [
        "T004"
      ]
    },
    {
      "theme_id": "T007",
      "theme": "Debt and silence as the pre-churn signal",
      "first_seen": "2026-W17",
      "last_seen": "2026-W18",
      "recurrence_count": 4,
      "lifecycle": "CHRONIC",
      "heat_score": 8,
      "okr": "OKR3",
      "notes": "Venues with outstanding balances + 14+ day silence = predictable churn. Classic combo: debt accumulates, venue disengages, stops using product, churns with balance on books. Billing disputes accelerate this \u2014 venues surprised by charges dispute them, go silent, churn. Dangerous new pattern: venues using T&C abuse as grounds for non-payment (Lulo Spice). Active: Alexander Mediterranean ($266 debt, 14+ day silence), Everest MoMo Station ($148.08 dispute). Migrated from SMS B-baseline \u2014 historically one of the strongest churn predictors in the dataset.",
      "jira_raised": false,
      "consolidated_from": [
        "T011",
        "T012",
        "T013"
      ]
    }
  ],
